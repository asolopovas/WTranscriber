{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["index.html", "e2e/**/*.spec.ts", "scripts/*.ts"],
  "project": ["src/**/*.{ts,vue}", "scripts/**/*.ts"],
  "ignoreDependencies": ["prettier", "tailwindcss", "@tailwindcss/forms"],
  "ignoreBinaries": ["powershell.exe", "adb", "cargo-audit", "taskkill", "scripts/run.ts"],
  "ignoreExportsUsedInFile": true
}
