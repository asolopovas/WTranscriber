#!/usr/bin/env bash
# Pre-commit gate optimised for fast LLM iteration:
#   - Auto-formats touched files and re-stages them (formatting is never a gate).
#   - Runs changed-file gates for checks that are cheap enough before commit.
#   - Skips src-tauri compile-heavy steps — those belong in explicit `just check` / release gates.
# All output uses `→` prefix lines so an agent can parse step boundaries.
set -e
cd "$(git rev-parse --show-toplevel)"

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

tauri_rust_files=$(echo "$staged" | grep -E '^src-tauri/.*\.rs$' || true)
xtask_rust_files=$(echo "$staged" | grep -E '^xtask/.*\.rs$' || true)
ts_vue_files=$(echo "$staged" | grep -E '^(src|scripts)/.*\.(ts|vue)$' || true)
prettier_other=$(echo "$staged" | grep -E '\.(json|jsonc|html|md|css|scss|yml|yaml)$' || true)

ran_any=0

if [ -n "$tauri_rust_files" ]; then
  echo "→ rust: cargo fmt src-tauri (auto-fix, touched files)"
  echo "$tauri_rust_files" | xargs cargo fmt --manifest-path src-tauri/Cargo.toml --
  echo "$tauri_rust_files" | xargs git add
  ran_any=1
fi

if [ -n "$xtask_rust_files" ]; then
  echo "→ rust: cargo fmt xtask (auto-fix, touched files)"
  echo "$xtask_rust_files" | xargs cargo fmt --manifest-path xtask/Cargo.toml --
  echo "$xtask_rust_files" | xargs git add
  ran_any=1
fi

if [ -n "$ts_vue_files" ]; then
  echo "→ ts/vue/scripts: prettier --write (auto-fix, touched files)"
  echo "$ts_vue_files" | xargs bun x prettier --write --log-level warn
  echo "$ts_vue_files" | xargs git add
  ran_any=1
fi

if [ -n "$prettier_other" ]; then
  echo "→ docs/config: prettier --write (auto-fix, touched files)"
  echo "$prettier_other" | xargs bun x prettier --write --log-level warn
  echo "$prettier_other" | xargs git add
  ran_any=1
fi

if [ "$ran_any" = 0 ]; then
  echo "→ no auto-format needed for staged files"
fi

echo "→ changed-file checks (gate)"
bun scripts/check-changed.ts --staged
