#!/usr/bin/env bash
set -e
cd "$(git rev-parse --show-toplevel)"

staged=$(git diff --cached --name-only --diff-filter=ACMR)
if [ -z "$staged" ]; then
  exit 0
fi

rust_files=$(echo "$staged" | grep -E '^src-tauri/.*\.rs$' || true)
cargo_toml_changed=$(echo "$staged" | grep -E '^src-tauri/Cargo\.(toml|lock)$' || true)
ts_vue_files=$(echo "$staged" | grep -E '^src/.*\.(ts|vue)$' || true)
prettier_other=$(echo "$staged" | grep -E '\.(json|html|md)$' || true)

ran_any=0

if [ -n "$rust_files" ] || [ -n "$cargo_toml_changed" ]; then
  echo "→ rust changed: cargo fmt --check + clippy"
  cargo fmt --manifest-path src-tauri/Cargo.toml --all -- --check
  cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --offline -- -D warnings
  ran_any=1
fi

if [ -n "$ts_vue_files" ]; then
  echo "→ ts/vue changed: prettier + vue-tsc"
  echo "$ts_vue_files" | xargs bun x prettier --check
  bun run typecheck
  ran_any=1
fi

if [ -n "$prettier_other" ] && [ -z "$ts_vue_files" ]; then
  echo "→ docs changed: prettier"
  echo "$prettier_other" | xargs bun x prettier --check
  ran_any=1
fi

if [ "$ran_any" = 0 ]; then
  echo "→ no checks needed for staged files"
fi
