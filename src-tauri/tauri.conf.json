{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WTranscriber",
  "version": "0.1.0",
  "identifier": "com.asolopovas.wtranscriber",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "WTranscriber",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb"],
    "linux": {
      "deb": {
        "depends": [
          "libc6 (>= 2.36)",
          "libstdc++6 (>= 12)",
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1 | libappindicator3-1",
          "ca-certificates",
          "curl",
          "bzip2",
          "tar"
        ],
        "recommends": ["ffmpeg"]
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
