{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Android: Attach Tauri (lldb)",
      "type": "lldb",
      "request": "attach",
      "pid": "${command:pickProcess}",
      "initCommands": [
        "platform select remote-android",
        "platform connect connect://localhost:5039"
      ]
    }
  ]
}
